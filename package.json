{
  "name": "c-quant",
  "version": "0.1.0",
  "private": true,
  "description": "Desktop research and strategy workstation for carbon allowance markets.",
  "main": "main.js",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "wait-on tcp:5173 && electron .",
    "build": "vite build",
    "preview": "vite preview",
    "autonomy:cycle": "powershell -ExecutionPolicy Bypass -File scripts/run-autonomous-cycle.ps1",
    "autonomy:release": "powershell -ExecutionPolicy Bypass -File scripts/run-autonomous-cycle.ps1 -WithPackaging",
    "autonomy:start": "powershell -ExecutionPolicy Bypass -File scripts/autonomy-control.ps1 -Action start",
    "autonomy:resume": "powershell -ExecutionPolicy Bypass -File scripts/autonomy-control.ps1 -Action resume",
    "autonomy:pause": "powershell -ExecutionPolicy Bypass -File scripts/autonomy-control.ps1 -Action pause",
    "autonomy:stop": "powershell -ExecutionPolicy Bypass -File scripts/autonomy-control.ps1 -Action stop",
    "autonomy:idle": "powershell -ExecutionPolicy Bypass -File scripts/autonomy-control.ps1 -Action idle",
    "autonomy:status": "powershell -ExecutionPolicy Bypass -File scripts/autonomy-control.ps1 -Action status",
    "autonomy:monitor": "node tools/autonomy-monitor/server.mjs",
    "autonomy:monitor:open": "powershell -ExecutionPolicy Bypass -File scripts/open-autonomy-monitor.ps1",
    "smoke:dir": "powershell -ExecutionPolicy Bypass -File scripts/smoke-cquant.ps1 -Mode dir",
    "smoke:portable": "powershell -ExecutionPolicy Bypass -File scripts/smoke-cquant.ps1 -Mode portable",
    "smoke:release": "powershell -ExecutionPolicy Bypass -File scripts/smoke-cquant.ps1 -Mode all",
    "package:dir": "powershell -ExecutionPolicy Bypass -File scripts/stop-running-cquant.ps1 && npm.cmd run build && set CSC_IDENTITY_AUTO_DISCOVERY=false && electron-builder --win dir",
    "package:portable": "powershell -ExecutionPolicy Bypass -File scripts/stop-running-cquant.ps1 && npm.cmd run build && set CSC_IDENTITY_AUTO_DISCOVERY=false && electron-builder --win portable"
  },
  "engines": {
    "node": ">=24"
  },
  "author": "Codex",
  "dependencies": {
    "exceljs": "^4.4.0",
    "lightweight-charts": "^5.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^4.3.0",
    "concurrently": "^9.2.1",
    "electron": "^41.2.0",
    "electron-builder": "^26.0.12",
    "typescript": "^6.0.2",
    "vite": "^8.0.7",
    "wait-on": "^9.0.5"
  },
  "build": {
    "appId": "com.cquant.desktop",
    "productName": "C-Quant",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "assets/**/*",
      "electron/**/*",
      "main.js",
      "preload.js",
      "package.json"
    ],
    "win": {
      "signAndEditExecutable": false,
      "icon": "assets/app-icon.ico",
      "target": [
        "portable"
      ],
      "artifactName": "C-Quant-${version}.${ext}"
    }
  }
}
